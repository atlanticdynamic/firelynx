# Gateway integration fixture: an MCP server exposing typed app tools.
# Typed apps implement MCPTypedToolProvider so mcp-io auto-derives their
# input/output schemas from Go types.

[[listeners]]
id = "test-listener"
address = ":{{.Port}}"
type = "http"

[[endpoints]]
id = "test-endpoint"
listener_id = "test-listener"

[[endpoints.routes]]
app_id = "mcp-server"
[endpoints.routes.http]
path_prefix = "/mcp"
method = "*"

[[apps]]
id = "echo-app"
type = "echo"
[apps.echo]
response = "ack"

[[apps]]
id = "calc-app"
type = "calculation"
[apps.calculation]

[[apps]]
id = "mcp-server"
type = "mcp"

[[apps.mcp.tools]]
app_id = "echo-app"

[[apps.mcp.tools]]
app_id = "calc-app"
